#!/usr/bin/env bash
# 🏛️ YJCryptoSignal Control — Professional Operations Management
set -euo pipefail

BOT_SERVICE="yjcryptosignal-bot"
SCANNER_SERVICE="yjcryptosignal-scanner"
PROJECT_DIR="/root/projects/YJCryptoSignal/Dev"

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; NC='\033[0m'; BOLD='\033[1m'

help() {
    echo -e "${CYAN}🏛️ YJCryptoSignal Operations Control${NC}"
    echo "Usage: yjcryptosignal-ctl <command> [target]"
    echo ""
    echo "Commands:"
    echo "  status                  Show bot and scanner status"
    echo "  start    [bot|scanner|all] Start service(s)"
    echo "  stop     [bot|scanner|all] Stop service(s)"
    echo "  restart  [bot|scanner|all] Restart service(s)"
    echo "  logs     [bot|scanner|all] [n] Show logs (last n lines)"
    echo "  watch    [bot|scanner|all] Tail logs in real-time"
    echo "  enable   [bot|scanner|all] Enable auto-start on boot"
    echo "  disable  [bot|scanner|all] Disable auto-start"
    echo "  venv                     Rebuild development Python venv"
    echo "  doctor                  Full system health check"
}

status_bar() {
    local label="$1" status="$2" mem="$3" pid="$4" uptime="$5"
    if [[ "$status" == "active (running)" ]]; then
        echo -e "  ${GREEN}●${NC} ${BOLD}$label${NC}  mem=${mem}  pid=${pid}  uptime=${uptime}"
    else
        echo -e "  ${RED}✗${NC} ${BOLD}$label${NC}  status=${status}"
    fi
}

cmd_status() {
    echo -e "${CYAN}═══════════════════════════════════════${NC}"
    echo -e "${BOLD}🏛️  YJCryptoSignal System Status${NC}"
    echo -e "${CYAN}═══════════════════════════════════════${NC}"
    
    for svc in $BOT_SERVICE $SCANNER_SERVICE; do
        local s=$(systemctl is-active "$svc" 2>/dev/null || echo "not found")
        local mem="—"; local pid="—"; local uptime="—"
        if [[ "$s" == "active" ]]; then
            mem=$(systemctl show "$svc" -p MemoryCurrent --value 2>/dev/null | numfmt --to=iec 2>/dev/null || echo "?")
            pid=$(systemctl show "$svc" -p MainPID --value 2>/dev/null)
            uptime=$(systemctl show "$svc" -p ActiveEnterTimestamp --value 2>/dev/null | sed 's/.*2\(.*\)/\1/' || echo "?")
        fi
        local label="$svc"
        [[ "$svc" == "$BOT_SERVICE" ]] && label+=" (V3 Bot)" || label+=" (V3 Scanner)"
        status_bar "$label" "$s" "$mem" "$pid" "$uptime"
    done
    
    echo ""
    echo -e "${CYAN}📊 Resource Overview:${NC}"
    echo "  $(free -h | grep Mem | awk '{print "RAM: " $3 " / " $2}')"
    echo "  $(df -h / | tail -1 | awk '{print "Disk: " $3 " / " $2 " (" $5 ")"}')"
    
    echo ""
    echo -e "${CYAN}🔒 Isolation Check:${NC}"
    local dev_venv="/root/projects/YJCryptoSignal/Dev/venv/bin/python3"
    local hermes_venv="/usr/local/lib/hermes-agent/venv/bin/python3"
    [[ -x "$dev_venv" ]] && echo -e "  🐍 Local Dev venv: ${GREEN}✓${NC}" || echo -e "  🐍 Local Dev venv: ${RED}✗${NC}"
    [[ -x "$hermes_venv" ]] && echo -e "  🐍 Hermes Prod venv: ${GREEN}✓${NC}" || echo -e "  🐍 Hermes Prod venv: ${RED}✗${NC}"
    
    # Check memory limits
    local v1_mem=$(systemctl show $BOT_SERVICE -p MemoryMax --value 2>/dev/null)
    local v2_mem=$(systemctl show $SCANNER_SERVICE -p MemoryMax --value 2>/dev/null)
    echo -e "  🛡️ Bot MemoryMax: ${v1_mem:-none}"
    echo -e "  🛡️ Scanner MemoryMax: ${v2_mem:-none}"
    
    # Check lock files
    [[ -f /tmp/yjcryptosignal-bot.lock ]] && echo -e "  🔒 Bot lock: $(cat /tmp/yjcryptosignal-bot.lock)" || echo -e "  🔒 Bot lock: ${RED}absent${NC}"
    [[ -f /tmp/yjcryptosignal-scanner.lock ]] && echo -e "  🔒 Scanner lock: $(cat /tmp/yjcryptosignal-scanner.lock)" || echo -e "  🔒 Scanner lock: ${RED}absent${NC}"
}

cmd_logs() {
    local target="${1:-both}" lines="${2:-50}"
    local filters=()
    case "$target" in
        bot) filters=("$BOT_SERVICE") ;;
        scanner) filters=("$SCANNER_SERVICE") ;;
        all|both) filters=("$BOT_SERVICE" "$SCANNER_SERVICE") ;;
        *) echo "Unknown target: $target"; exit 1 ;;
    esac
    for svc in "${filters[@]}"; do
        echo -e "${CYAN}─── $svc ───${NC}"
        journalctl -u "$svc" --no-pager -n "$lines" 2>/dev/null || echo "(no logs)"
    done
}

cmd_watch() {
    local target="${1:-all}"
    case "$target" in
        bot) journalctl -u "$BOT_SERVICE" -f ;;
        scanner) journalctl -u "$SCANNER_SERVICE" -f ;;
        all|both) journalctl -u "$BOT_SERVICE" -u "$SCANNER_SERVICE" -f ;;
        *) echo "Unknown target: $target"; exit 1 ;;
    esac
}

cmd_start_stop_restart() {
    local action="$1" target="${2:-all}"
    local services=()
    case "$target" in
        bot) services=("$BOT_SERVICE") ;;
        scanner) services=("$SCANNER_SERVICE") ;;
        all|both) services=("$BOT_SERVICE" "$SCANNER_SERVICE") ;;
        *) echo "Unknown target: $target"; exit 1 ;;
    esac
    for svc in "${services[@]}"; do
        echo -e "  ${BOLD}$action $svc...${NC}"
        systemctl "$action" "$svc"
    done
}

cmd_enable_disable() {
    local action="$1" target="${2:-all}"
    local services=()
    case "$target" in
        bot) services=("$BOT_SERVICE") ;;
        scanner) services=("$SCANNER_SERVICE") ;;
        all|both) services=("$BOT_SERVICE" "$SCANNER_SERVICE") ;;
        *) echo "Unknown target: $target"; exit 1 ;;
    esac
    for svc in "${services[@]}"; do
        systemctl "$action" "$svc"
        echo -e "  $action $svc: ${GREEN}✓${NC}"
    done
}

cmd_venv() {
    echo -e "  ${YELLOW}Rebuilding Dev venv...${NC}"
    cd "$PROJECT_DIR"
    rm -rf venv
    python3 -m venv venv
    source venv/bin/activate
    pip install --quiet -r requirements.txt
    echo -e "  ${GREEN}Dev venv ready${NC}"
}

cmd_doctor() {
    local exit_code=0
    
    echo -e "${CYAN}═══════════════════════════════════════${NC}"
    echo -e "${BOLD}🩺 YJCryptoSignal Full Health Check${NC}"
    echo -e "${CYAN}═══════════════════════════════════════${NC}"
    
    echo -e "\n${BOLD}1. Services${NC}"
    for svc in $BOT_SERVICE $SCANNER_SERVICE; do
        local s=$(systemctl is-active "$svc" 2>/dev/null)
        if [[ "$s" == "active" ]]; then
            echo -e "  ${GREEN}✓${NC} $svc: running"
        else
            echo -e "  ${RED}✗${NC} $svc: $s"
            exit_code=1
        fi
    done
    
    echo -e "\n${BOLD}2. Python Venvs${NC}"
    local venv_paths=("/root/projects/YJCryptoSignal/Dev/venv/bin/python3" "/usr/local/lib/hermes-agent/venv/bin/python3")
    for venv in "${venv_paths[@]}"; do
        if [[ -x "$venv" ]]; then
            local ver=$("$venv" --version 2>/dev/null)
            echo -e "  ${GREEN}✓${NC} $venv: $ver"
        else
            echo -e "  ${RED}✗${NC} $venv: NOT FOUND"
            exit_code=1
        fi
    done
    
    echo -e "\n${BOLD}3. Memory Limits${NC}"
    for svc in $BOT_SERVICE $SCANNER_SERVICE; do
        local mem=$(systemctl show "$svc" -p MemoryMax --value 2>/dev/null)
        if [[ -n "$mem" && "$mem" != "infinity" && "$mem" != "18446744073709551615" ]]; then
            echo -e "  ${GREEN}✓${NC} $svc: $mem"
        else
            echo -e "  ${RED}✗${NC} $svc: NO memory limit"
            exit_code=1
        fi
    done
    
    echo -e "\n${BOLD}4. Lock Files${NC}"
    [[ -f /tmp/yjcryptosignal-bot.lock ]] && echo -e "  ${GREEN}✓${NC} Bot lock present" || { echo -e "  ${YELLOW}⚠${NC} Bot lock absent" ; }
    [[ -f /tmp/yjcryptosignal-scanner.lock ]] && echo -e "  ${GREEN}✓${NC} Scanner lock present" || { echo -e "  ${YELLOW}⚠${NC} Scanner lock absent" ; }
    
    echo -e "\n${BOLD}5. Network Connectivity${NC}"
    if curl -s --max-time 5 https://api.telegram.org >/dev/null 2>&1; then
        echo -e "  ${GREEN}✓${NC} Telegram API reachable"
    else
        echo -e "  ${RED}✗${NC} Telegram API unreachable"
        exit_code=1
    fi
    
    echo ""
    if [[ $exit_code -eq 0 ]]; then
        echo -e "  ${GREEN}✅ ALL CHECKS PASSED${NC}"
    else
        echo -e "  ${RED}❌ SOME CHECKS FAILED${NC}"
    fi
    return $exit_code
}

# ─── MAIN ───
case "${1:-help}" in
    status)     cmd_status ;;
    logs)       cmd_logs "${2:-both}" "${3:-50}" ;;
    watch)      cmd_watch "${2:-all}" ;;
    start)      cmd_start_stop_restart "start" "${2:-all}" ;;
    stop)       cmd_start_stop_restart "stop" "${2:-all}" ;;
    restart)    cmd_start_stop_restart "restart" "${2:-all}" ;;
    enable)     cmd_enable_disable "enable" "${2:-all}" ;;
    disable)    cmd_enable_disable "disable" "${2:-all}" ;;
    venv)       cmd_venv ;;
    doctor)     cmd_doctor ;;
    help|*)     help ;;
esac
