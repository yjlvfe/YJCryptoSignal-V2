# YJCryptoSignal — Environment Variables
# انسخ هذا الملف إلى .env واملأ القيم الفعلية
# cp .env.example .env

# ═══════════════════════════════════════════
# 🤖 TELEGRAM CREDENTIALS
# ═══════════════════════════════════════════
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
#   Primary bot token (new standard). Loaded by all new-system components.
# TELEGRAM_CHAT_ID=your-chat-id-here
#   Chat/user ID for proactive alerts. Falls back to OWNER_ID if not set.
# BOT_TOKEN=your-telegram-bot-token-here
#   Legacy fallback. Use TELEGRAM_BOT_TOKEN instead for new deployments.

# ═══════════════════════════════════════════
# 🧠 MULTI-PROVIDER AI ROUTER — Auto-Failover & Key Rotation
# ═══════════════════════════════════════════
# Each provider: NAME, BASE_URL, MODELS (comma-separated), KEYS (comma-separated for rotation),
# MAX_RPM, MAX_RPD (requests per day), PRIORITY (1=highest)
# Multiple keys per provider = round-robin rotation for durability

# Global AI settings
# AI_MAX_TOKENS=900
# AI_TIMEOUT=45
# AI_MAX_RETRIES=10
# AI_RETRY_BASE_DELAY=0.5
# AI_GLOBAL_MIN_INTERVAL=2.0

# Provider 1 (Priority 1 - Fastest)
# AI_PROVIDER_1_NAME=SambaNova
# AI_PROVIDER_1_BASE_URL=https://api.sambanova.ai/v1
# AI_PROVIDER_1_MODELS=Meta-Llama-3.3-70B-Instruct
# AI_PROVIDER_1_KEYS=key1,key2,key3
# AI_PROVIDER_1_MAX_RPM=60
# AI_PROVIDER_1_MAX_RPD=20000
# AI_PROVIDER_1_PRIORITY=1

# Provider 2 (Priority 2)
# AI_PROVIDER_2_NAME=Mistral
# AI_PROVIDER_2_BASE_URL=https://api.mistral.ai/v1
# AI_PROVIDER_2_MODELS=mistral-small-latest
# AI_PROVIDER_2_KEYS=key1
# AI_PROVIDER_2_MAX_RPM=30
# AI_PROVIDER_2_MAX_RPD=5000
# AI_PROVIDER_2_PRIORITY=2

# Provider 3 (Priority 3)
# AI_PROVIDER_3_NAME=NVIDIA
# AI_PROVIDER_3_BASE_URL=https://integrate.api.nvidia.com/v1
# AI_PROVIDER_3_MODELS=meta/llama-3.1-8b-instruct,meta/llama-3.3-70b-instruct
# AI_PROVIDER_3_KEYS=key1
# AI_PROVIDER_3_MAX_RPM=30
# AI_PROVIDER_3_MAX_RPD=5000
# AI_PROVIDER_3_PRIORITY=3

# Provider 4 (Priority 4)
# AI_PROVIDER_4_NAME=Cloudflare_Backup
# AI_PROVIDER_4_BASE_URL=https://api.cloudflare.com/client/v4/accounts/YOUR_ACCOUNT_ID/ai/run
# AI_PROVIDER_4_MODELS=@cf/meta/llama-3.3-70b-instruct-fp8-fast
# AI_PROVIDER_4_KEYS=key1
# AI_PROVIDER_4_MAX_RPM=50
# AI_PROVIDER_4_MAX_RPD=10000
# AI_PROVIDER_4_PRIORITY=4

# Provider 5 (Priority 5)
# AI_PROVIDER_5_NAME=Novita
# AI_PROVIDER_5_BASE_URL=https://api.novita.ai/v3/openai
# AI_PROVIDER_5_MODELS=meta-llama/llama-3.1-8b-instruct
# AI_PROVIDER_5_KEYS=key1
# AI_PROVIDER_5_MAX_RPM=30
# AI_PROVIDER_5_MAX_RPD=5000
# AI_PROVIDER_5_PRIORITY=5

# Provider 6 (Priority 6 - Last Resort)
# AI_PROVIDER_6_NAME=LLM7
# AI_PROVIDER_6_BASE_URL=https://api.llm7.io/v1
# AI_PROVIDER_6_MODELS=gpt-4o-mini
# AI_PROVIDER_6_KEYS=key1
# AI_PROVIDER_6_MAX_RPM=30
# AI_PROVIDER_6_MAX_RPD=5000
# AI_PROVIDER_6_PRIORITY=6

# ═══════════════════════════════════════════
# 🌐 DATA FETCHER SETTINGS
# ═══════════════════════════════════════════
# FETCHER_CACHE_TTL=3600
# FETCHER_TIMEOUT=15
# FETCHER_MAX_RETRIES=3

# ═══════════════════════════════════════════
# 📊 TRADING SETTINGS
# ═══════════════════════════════════════════
# MAX_ACTIVE_TRADES=10
# DEFAULT_POSITION_PCT=10.0
# MAX_PORTFOLIO_HEAT=15.0
# MAX_DRAWDOWN_PCT=20.0
# SCAN_INTERVAL_MINUTES=5
# SIGNAL_COOLDOWN_MINUTES=30

# ═══════════════════════════════════════════
# 📈 SCANNER SETTINGS
# ═══════════════════════════════════════════
# SCANNER_MIN_CONFIDENCE=40
# SCANNER_MIN_STRENGTH=25
# SCANNER_LIQUIDITY_MIN_SCORE=30
# SCANNER_ALIGNMENT_MIN=2

# ═══════════════════════════════════════════
# 👤 OWNER / ADMIN SETTINGS
# ═══════════════════════════════════════════
# OWNER_ID=528864559
# POSITION_SIZE_PCT=10.0

# ═══════════════════════════════════════════
# 📂 DATA DIRECTORY (overrides default)
# ═══════════════════════════════════════════
# DATA_DIR=/root/.yjcryptosignal-bot

# ═══════════════════════════════════════════
# 🔧 ADVANCED
# ═══════════════════════════════════════════
# LOG_LEVEL=INFO
# TZ=UTC
# METRICS_AUTH_TOKEN=your-prometheus-bearer-token
#   If set, the /metrics HTTP endpoint requires Authorization: Bearer <token>.
#   Health and readiness endpoints stay unauthenticated for load balancers.

# ═══════════════════════════════════════════
# 🔌 EXCHANGE API KEYS (Optional - for authenticated endpoints)
# ═══════════════════════════════════════════
# MEXC_API_KEY=
# MEXC_API_SECRET=
# BINANCE_API_KEY=
# BINANCE_API_SECRET=

# ═══════════════════════════════════════════
# 📊 METRICS PORTS
# ═══════════════════════════════════════════
# Ports for the Prometheus metrics servers to avoid host port conflicts
# SCANNER_METRICS_PORT=9090
# BOT_METRICS_PORT=9091
